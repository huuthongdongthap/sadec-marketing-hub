{
  "name": "sadec-marketing-hub",
  "version": "1.0.0",
  "description": "Sa Đéc Marketing Hub - Digital Marketing Agency",
  "scripts": {
    "dev": "npx http-server -p 8080 -o",
    "prebuild": "node scripts/tools/inject-env.js && node scripts/build/optimize-lazy.js",
    "build": "npm run build:minify",
    "build:minify": "node scripts/build/minify.js",
    "build:optimize": "node scripts/build/optimize-lazy.js",
    "optimize": "npm run build:optimize && npm run build:minify",
    "audit": "node scripts/audit/html-audit.js",
    "audit:fix": "node scripts/audit/fix-html.js",
    "migrate": "node database/migrate.js",
    "migrate:print": "node database/migrate.js --print",
    "migrate:run": "node database/run-migrations.js",
    "all-phases": "bash scripts/tools/run-all-phases.sh",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report"
  },
  "keywords": [
    "marketing",
    "agency",
    "material-design-3",
    "sadec"
  ],
  "author": "Sa Đéc Marketing Hub",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "clean-css-cli": "^5.6.2",
    "html-minifier-terser": "^7.2.0",
    "http-server": "^14.1.1",
    "pg": "^8.16.3",
    "terser": "^5.26.0"
  },
  "dependencies": {
    "jsdom": "^27.4.0"
  }
}