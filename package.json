{
  "name": "sadec-marketing-hub",
  "version": "1.0.0",
  "type": "module",
  "description": "Sa Đéc Marketing Hub - Digital Marketing Agency",
  "scripts": {
    "dev": "npx http-server -p 8080 -o",
    "prebuild": "node scripts/tools/inject-env.js && node scripts/build/optimize-lazy.js",
    "build": "npm run build:minify",
    "build:minify": "node scripts/build/minify.js",
    "build:optimize": "node scripts/build/optimize-lazy.js",
    "build:css-bundle": "node scripts/build/css-bundle.js",
    "build:cache": "node scripts/build/cache-busting.js",
    "optimize": "npm run build:css-bundle && npm run build:optimize && npm run build:minify",
    "optimize:full": "node scripts/optimize-all.js",
    "optimize:run": "npm run build:optimize && npm run build:cache",
    "audit": "node scripts/audit/index.js",
    "audit:fix": "node scripts/audit/index.js --fix",
    "audit:links": "node scripts/audit/index.js --scan links",
    "audit:meta": "node scripts/audit/index.js --scan meta",
    "audit:a11y": "node scripts/audit/index.js --scan a11y",
    "audit:ids": "node scripts/audit/index.js --scan ids",
    "audit:json": "node scripts/audit/index.js --output json",
    "migrate": "node database/migrate.js",
    "migrate:print": "node database/migrate.js --print",
    "migrate:run": "node database/run-migrations.js",
    "all-phases": "bash scripts/tools/run-all-phases.sh",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "test:vitest:report": "vitest run --reporter=verbose",
    "perf:audit": "node scripts/perf/audit.js",
    "perf:lazy-load": "python3 scripts/perf/add-lazy-load.py",
    "perf:bundle-report": "node scripts/perf/bundle-report.js",
    "perf:critical-css": "node scripts/perf/critical-css.js",
    "perf:inject-critical": "node scripts/perf/inject-critical-css.js",
    "perf:optimize": "node scripts/perf/optimize-all.js",
    "perf:optimize:run": "node scripts/perf/optimize-performance.js",
    "build:critical": "npm run perf:critical-css && npm run perf:inject-critical",
    "perf:all": "npm run optimize:full && npm run perf:optimize",
    "perf:cache-headers": "node scripts/perf/generate-cache-headers.js",
    "perf:dedupe": "node scripts/dedupe-dns-prefetch.js"
  },
  "keywords": [
    "marketing",
    "agency",
    "material-design-3",
    "sadec"
  ],
  "author": "Sa Đéc Marketing Hub",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "clean-css-cli": "^5.6.2",
    "happy-dom": "^20.8.4",
    "html-minifier-terser": "^7.2.0",
    "http-server": "^14.1.1",
    "jsdom": "^28.1.0",
    "pg": "^8.16.3",
    "terser": "^5.26.0",
    "vitest": "^4.1.0"
  }
}
