<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="../favicon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lead Management - Mekong Agency Admin</title>
    <meta name="description"
        content="Lead management system for tracking prospects, scoring, and conversion optimization in marketing campaigns.">

    <script type="importmap">
    {"imports": {"@material/web/": "https://esm.run/@material/web/"}}
  </script>
    <script type="module">import '@material/web/all.js';</script>

    <link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Symbols+Outlined" rel="stylesheet">
    <link rel="stylesheet" href="../assets/css/m3-agency.css">
    <link rel="stylesheet" href="../assets/css/admin-unified.css">
    <link rel="stylesheet" href="../assets/css/admin-unified.css">

    

    <!-- Web Components -->
    <script src="../assets/js/components/sadec-sidebar.js"></script>
    <link rel="stylesheet" href="../assets/css/admin-leads.css">
</head>

<body>
    <div class="admin-layout">
        <!-- Sidebar -->
        <!-- Sidebar - Using Web Component -->
        <sadec-sidebar active="leads"></sadec-sidebar>

        <!-- Main Content -->
        <main class="main-content">
            <div class="top-bar">
                <div>
                    <h1 class="page-title" style="font-size: 24px; margin: 0;">Lead Management</h1>
                    <div class="body-medium text-muted">Quản lý và chuyển đổi leads</div>
                </div>
                <button class="btn btn-filled">
                    <span class="material-symbols-outlined">add</span>
                    Thêm Lead
                </button>
            </div>

            <!-- Toolbar -->
            <div class="toolbar">
                <div class="search-box">
                    <span class="material-symbols-outlined text-muted">search</span>
                    <input type="text" placeholder="Tìm kiếm leads..." aria-label="Tìm kiếm leads">
                </div>
                <div class="filter-group">
                    <select class="filter-dropdown" aria-label="Lọc theo trạng thái">
                        <option value="all">Tất cả trạng thái</option>
                        <option value="hot">🔥 Hot Leads (Priority)</option>
                        <option value="warm">⭐ Warm Leads</option>
                        <option value="cold">❄️ Cold Leads</option>
                    </select>
                    <button class="btn btn-outlined" id="sortBtn">
                        <span class="material-symbols-outlined">sort</span>
                        Sắp xếp: Điểm cao nhất
                    </button>
                </div>
                <select class="filter-dropdown" aria-label="Lọc theo nguồn">
                    <option>Tất cả nguồn</option>
                    <option>Facebook</option>
                    <option>Website</option>
                    <option>Zalo</option>
                    <option>Referral</option>
                </select>
            </div>

            <!-- Pipeline View -->
            <div class="pipeline-view">
                <div class="pipeline-column" data-stage="new">
                    <div class="pipeline-header">
                        <span class="pipeline-title">Mới</span>
                        <span class="pipeline-count">12</span>
                    </div>
                    <div class="pipeline-leads">
                        <div class="pipeline-lead">
                            <div class="pipeline-lead-name">Trần Thanh Lan</div>
                            <div class="pipeline-lead-company">Cửa hàng hoa Hương Sen</div>
                        </div>
                        <div class="pipeline-lead">
                            <div class="pipeline-lead-name">Nguyễn Văn Minh</div>
                            <div class="pipeline-lead-company">Nhà hàng Mekong</div>
                        </div>
                        <div class="pipeline-lead">
                            <div class="pipeline-lead-name">Phạm Hoàng</div>
                            <div class="pipeline-lead-company">Gym Fitness Pro</div>
                        </div>
                    </div>
                </div>

                <div class="pipeline-column" data-stage="contacted">
                    <div class="pipeline-header">
                        <span class="pipeline-title">Đang liên hệ</span>
                        <span class="pipeline-count">8</span>
                    </div>
                    <div class="pipeline-leads">
                        <div class="pipeline-lead">
                            <div class="pipeline-lead-name">Lê Thị Hoa</div>
                            <div class="pipeline-lead-company">Spa & Beauty Center</div>
                        </div>
                        <div class="pipeline-lead">
                            <div class="pipeline-lead-name">Võ Minh Tuấn</div>
                            <div class="pipeline-lead-company">Tiệm bánh Hạnh Phúc</div>
                        </div>
                    </div>
                </div>

                <div class="pipeline-column" data-stage="qualified">
                    <div class="pipeline-header">
                        <span class="pipeline-title">Đã gửi báo giá</span>
                        <span class="pipeline-count">5</span>
                    </div>
                    <div class="pipeline-leads">
                        <div class="pipeline-lead">
                            <div class="pipeline-lead-name">Đặng Văn Long</div>
                            <div class="pipeline-lead-company">Khách sạn Riverside</div>
                        </div>
                        <div class="pipeline-lead">
                            <div class="pipeline-lead-name">Huỳnh Thanh Mai</div>
                            <div class="pipeline-lead-company">Thời trang XYZ</div>
                        </div>
                    </div>
                </div>

                <div class="pipeline-column" data-stage="won">
                    <div class="pipeline-header">
                        <span class="pipeline-title">Chốt đơn</span>
                        <span class="pipeline-count">3</span>
                    </div>
                    <div class="pipeline-leads">
                        <div class="pipeline-lead">
                            <div class="pipeline-lead-name">Trương Công Danh</div>
                            <div class="pipeline-lead-company">Công ty TNHH ABC</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Leads Grid -->
            <div style="margin-top: 32px;">
                <h2 class="title-large mb-24">Tất cả Leads</h2>
                <div class="leads-grid">
                    <!-- Lead 1 -->
                    <div class="card card-elevated lead-card">
                        <div class="lead-header">
                            <div class="lead-avatar"
                                style="background: var(--md-sys-color-primary-container); color: var(--md-sys-color-primary);">
                                TL</div>
                            <div class="lead-info">
                                <div class="lead-name">Trần Thanh Lan</div>
                                <div class="lead-company">Cửa hàng hoa Hương Sen</div>
                            </div>
                            <span class="lead-score-badge hot">A - 95</span>
                        </div>
                        <div class="lead-details">
                            <div class="lead-detail">
                                <span class="material-symbols-outlined">phone</span>
                                0915 997 989
                            </div>
                            <div class="lead-detail">
                                <span class="material-symbols-outlined">mail</span>
                                lan@huongsen.vn
                            </div>
                            <div class="lead-detail">
                                <span class="material-symbols-outlined">location_on</span>
                                Sa Đéc, Đồng Tháp
                            </div>
                        </div>
                        <div class="lead-source">
                            <span class="material-symbols-outlined" style="font-size: 14px;">thumb_up</span>
                            Facebook
                        </div>
                        <div class="lead-actions">
                            <button class="lead-action-btn">
                                <span class="material-symbols-outlined">call</span>
                                Gọi
                            </button>
                            <button class="lead-action-btn">
                                <span class="material-symbols-outlined">mail</span>
                                Email
                            </button>
                            <button class="lead-action-btn">
                                <span class="material-symbols-outlined">edit</span>
                                Sửa
                            </button>
                        </div>
                    </div>

                    <!-- Lead 2 -->
                    <div class="card card-elevated lead-card">
                        <div class="lead-header">
                            <div class="lead-avatar"
                                style="background: var(--md-sys-color-secondary-container); color: var(--md-sys-color-secondary);">
                                NM</div>
                            <div class="lead-info">
                                <div class="lead-name">Nguyễn Văn Minh</div>
                                <div class="lead-company">Nhà hàng Mekong</div>
                            </div>
                            <span class="lead-score-badge warm">B - 75</span>
                        </div>
                        <div class="lead-details">
                            <div class="lead-detail">
                                <span class="material-symbols-outlined">phone</span>
                                0918 765 432
                            </div>
                            <div class="lead-detail">
                                <span class="material-symbols-outlined">mail</span>
                                minh@mekongrest.vn
                            </div>
                            <div class="lead-detail">
                                <span class="material-symbols-outlined">location_on</span>
                                Cần Thơ
                            </div>
                        </div>
                        <div class="lead-source">
                            <span class="material-symbols-outlined" style="font-size: 14px;">language</span>
                            Website
                        </div>
                        <div class="lead-actions">
                            <button class="lead-action-btn">
                                <span class="material-symbols-outlined">call</span>
                                Gọi
                            </button>
                            <button class="lead-action-btn">
                                <span class="material-symbols-outlined">mail</span>
                                Email
                            </button>
                            <button class="lead-action-btn">
                                <span class="material-symbols-outlined">edit</span>
                                Sửa
                            </button>
                        </div>
                    </div>

                    <!-- Lead 3 -->
                    <div class="card card-elevated lead-card">
                        <div class="lead-header">
                            <div class="lead-avatar"
                                style="background: var(--md-sys-color-tertiary-container); color: var(--md-sys-color-tertiary);">
                                PH</div>
                            <div class="lead-info">
                                <div class="lead-name">Phạm Hoàng</div>
                                <div class="lead-company">Gym Fitness Pro</div>
                            </div>
                            <span class="lead-score-badge cold">D - 30</span>
                        </div>
                        <div class="lead-details">
                            <div class="lead-detail">
                                <span class="material-symbols-outlined">phone</span>
                                0977 111 222
                            </div>
                            <div class="lead-detail">
                                <span class="material-symbols-outlined">mail</span>
                                hoang@fitnesspro.vn
                            </div>
                            <div class="lead-detail">
                                <span class="material-symbols-outlined">location_on</span>
                                Long Xuyên, An Giang
                            </div>
                        </div>
                        <div class="lead-source">
                            <span class="material-symbols-outlined" style="font-size: 14px;">chat</span>
                            Zalo
                        </div>
                        <div class="lead-actions">
                            <button class="lead-action-btn">
                                <span class="material-symbols-outlined">call</span>
                                Gọi
                            </button>
                            <button class="lead-action-btn">
                                <span class="material-symbols-outlined">mail</span>
                                Email
                            </button>
                            <button class="lead-action-btn">
                                <span class="material-symbols-outlined">edit</span>
                                Sửa
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Admin Client Script -->
    <script type="module" src="../assets/js/admin-client.js"></script>
    <script src="../assets/js/admin-shared.js"></script>
    <!-- Content AI -->
    <script src="../assets/js/content-ai.js"></script>
    <!-- Central State Management -->
    <script src="../assets/js/mekong-store.js"></script>
    <!-- Realtime Updates -->
    <script src="../assets/js/realtime-dashboard.js"></script>
    <!-- Data Sync Integration -->
    <script src="../assets/js/data-sync-init.js"></script>
    <!-- Mobile Menu -->
    <script src="../assets/js/mobile-menu.js"></script>
</body>

</html>